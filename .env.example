# Prisma runtime connection: use the Supabase pooled connection string.
DATABASE_URL="postgresql://postgres.PROJECT_REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Prisma CLI connection: use the direct database connection string.
DIRECT_URL="postgresql://postgres:YOUR_DB_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres"

# Optional admin seed values. Safe defaults are built in.
ADMIN_ACCOUNT="admin"
ADMIN_PASSWORD="change-me-before-production"

# Optional for local development. Strongly recommended before production deploy.
# ADMIN_JWT_SECRET="change-this-secret-before-production"
